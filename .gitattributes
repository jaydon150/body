# Normalize line endings: text files use LF in repo, OS-native on checkout
* text=auto eol=lf

# Explicit text types
*.md text
*.json text
*.yml text
*.yaml text
*.ts text
*.tsx text
*.js text
*.jsx text
*.css text
*.html text
*.glsl text
*.vert text
*.frag text

# Common binary types (not LFS-tracked — small images, fonts)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg text
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary

# LFS: 3D mesh formats
*.glb filter=lfs diff=lfs merge=lfs -text
*.gltf filter=lfs diff=lfs merge=lfs -text
*.obj filter=lfs diff=lfs merge=lfs -text
*.fbx filter=lfs diff=lfs merge=lfs -text
*.dae filter=lfs diff=lfs merge=lfs -text
*.stl filter=lfs diff=lfs merge=lfs -text
*.ply filter=lfs diff=lfs merge=lfs -text
*.usd filter=lfs diff=lfs merge=lfs -text
*.usdc filter=lfs diff=lfs merge=lfs -text
*.usdz filter=lfs diff=lfs merge=lfs -text
*.blend filter=lfs diff=lfs merge=lfs -text

# LFS: large texture formats
*.exr filter=lfs diff=lfs merge=lfs -text
*.hdr filter=lfs diff=lfs merge=lfs -text
*.ktx filter=lfs diff=lfs merge=lfs -text
*.ktx2 filter=lfs diff=lfs merge=lfs -text
*.basis filter=lfs diff=lfs merge=lfs -text

# LFS: medical imaging (deferred; reserved for future phases)
*.nrrd filter=lfs diff=lfs merge=lfs -text
*.nii filter=lfs diff=lfs merge=lfs -text
*.dcm filter=lfs diff=lfs merge=lfs -text

# LFS: large binary blobs in data/derived/
*.bin filter=lfs diff=lfs merge=lfs -text
